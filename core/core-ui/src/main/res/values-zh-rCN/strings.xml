    <!-- FloatMonitorType info texts -->
    <string name="monitor_load_info">显示 CPU、GPU、内存、电池的实时负载仪表盘。以 2x2 网格形式呈现四个圆弧仪表，直观展示系统资源使用情况。</string>
    <string name="monitor_process_info">显示当前 CPU 占用率最高的 5 个进程列表，包含进程名称和 CPU 使用百分比。帮助快速定位高负载进程。</string>
    <string name="monitor_thread_info">显示当前前台应用中 CPU 占用率最高的线程列表。用于深入分析应用性能瓶颈。</string>
    <string name="monitor_mini_info">极简单行模式，显示 CPU%/GPU%/温度/FPS/实时电流。占用屏幕空间最小，适合日常监控。</string>
    <string name="monitor_fps_info">实时帧率计数器，大字体显示当前 FPS 值，并统计卡顿 (Jank) 次数。适合游戏和动画性能测试。</string>
    <string name="monitor_temperature_info">显示设备多个温度传感器的实时读数，包括 CPU、GPU、电池等区域温度。用于监控设备散热状况。</string>

