    <!-- FloatMonitorType info texts -->
    <string name="monitor_load_info">CPU、GPU、メモリ、バッテリーのリアルタイム負荷ダッシュボード。2x2グリッドの4つのアークゲージで直感的にリソース状況を表示します。</string>
    <string name="monitor_process_info">CPU使用率上位5プロセスを表示。プロセス名とCPU使用率で高負荷プロセスを素早く特定。</string>
    <string name="monitor_thread_info">フォアグラウンドアプリのCPU使用率上位スレッドを表示。パフォーマンスボトルネックの詳細分析に。</string>
    <string name="monitor_mini_info">超ミニマル1行モード。CPU%%/GPU%%/温度/FPS/リアルタイム電流を表示。画面占有最小。</string>
    <string name="monitor_fps_info">リアルタイムFPSカウンター。現在のFPS値を大きく表示し、ジャンク回数を集計。ゲームやアニメーションのパフォーマンステストに最適。</string>
    <string name="monitor_temperature_info">CPU、GPU、バッテリーなど複数温度センサーのリアルタイム値を表示。デバイスの発熱状況を監視。</string>

